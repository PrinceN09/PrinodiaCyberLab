# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prinodia_cyberlab?schema=public"

# Secret used to sign session cookies. Use a long random string in production.
AUTH_SECRET="change-me-to-a-long-random-string"

# ── Job discovery (v0.4) ─────────────────────────────────────────
# Secret required by the scheduled-refresh endpoint (Phase 9).
# Point cron / GitHub Actions / Vercel Cron at:
#   POST /api/admin/jobs/refresh  with header  x-refresh-secret: <value>
JOBS_REFRESH_SECRET="change-me"

# Unofficial providers are OFF unless explicitly enabled (they use
# undocumented endpoints and may break or violate source ToS —
# review before enabling; see src/lib/jobs/registry.ts).
HIRING_CAFE_ENABLED="false"
WORKDAY_ENABLED="false"

# GitHub portfolio sync (Phase 7). Optional: a fine-grained token
# with public-repo read raises rate limits; public data works
# unauthenticated at 60 requests/hour.
GITHUB_USERNAME="PrinceN09"
GITHUB_TOKEN=""
