generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Core
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   @default("")
  role      String   @default("Security Analyst")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes            Note[]
  codeSnippets     CodeSnippet[]
  diagrams         Diagram[]
  projects         Project[]
  reports          Report[]
  learningProgress LearningProgress[]
  resources        Resource[]
  studyLogs        StudyLog[]
  studySessions    StudySession[]
  studyGoals       StudyGoal[]
  courses          Course[]
  flashcards       Flashcard[]
  resumes          Resume[]
  coverLetters     CoverLetter[]
  linkedInProfile  LinkedInProfile?
  jobApplications  JobApplication[]
  interviewPreps   InterviewPrep[]
  portfolioItems   PortfolioItem[]
  siemRules        SiemRule[]
  threatHunts      ThreatHunt[]
  iocs             Ioc[]
  userSkills       UserSkill[]
  certifications   Certification[]
  jobSearchPreference JobSearchPreference?
  portfolioRepos   PortfolioRepo[]
  labs             Lab[]
  cyberProjects    CybersecurityProject[]
  notifications    Notification[]
  notificationRules NotificationRule[]
  applicationInterviews  ApplicationInterview[]
  applicationAssessments ApplicationAssessment[]
  applicationOffers      ApplicationOffer[]
  applicationNotes       ApplicationNote[]
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[] @relation("FolderTree")
  notes     Note[]
  createdAt DateTime @default(now())
}

model Tag {
  id       String        @id @default(cuid())
  name     String        @unique
  color    String        @default("blue")
  notes    Note[]
  snippets CodeSnippet[]
  projects Project[]
}

/// Managed vocabulary for note categories (previously a free-text
/// string on Note). Created on demand from the note details form.
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("blue")
  notes     Note[]
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// Knowledge base
// ─────────────────────────────────────────────

enum NoteStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum NoteDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Note {
  id          String          @id @default(cuid())
  title       String
  summary     String?
  description String?
  content     String          @default("")
  status      NoteStatus      @default(DRAFT)
  difficulty  NoteDifficulty?
  pinned      Boolean         @default(false)
  favorite    Boolean         @default(false)
  categoryId  String?
  category    Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  folderId    String?
  folder      Folder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags        Tag[]
  lessonId    String?
  lesson      Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions    NoteVersion[]
  attachments Attachment[]
  links       NoteLink[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([folderId])
  @@index([lessonId])
  @@index([categoryId])
  @@index([status])
}

/// Immutable point-in-time snapshots of a note, captured by the
/// auto-save pipeline on every content change. Powers version
/// history (list, preview, restore). Never updated in place.
model NoteVersion {
  id        String   @id @default(cuid())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  title     String
  content   String
  cause     String   @default("autosave") // autosave | manual | restore
  createdAt DateTime @default(now())

  @@index([noteId, createdAt])
}

/// File attachment metadata. The binary lives on disk under
/// uploads/notes/<noteId>/ and is streamed via the attachments API.
model Attachment {
  id          String   @id @default(cuid())
  noteId      String
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  fileName    String
  mimeType    String
  size        Int
  storagePath String
  createdAt   DateTime @default(now())

  @@index([noteId])
}

enum NoteLinkType {
  COURSE
  LESSON
  PROJECT
  CODE_SNIPPET
  DIAGRAM
  STUDY_SESSION
  INTERVIEW_QUESTION
  PORTFOLIO_ITEM
  REPORT
  NOTE
}

/// Knowledge-graph edge from a note to any other entity in the
/// workspace (courses, lessons, snippets, other notes, …).
/// `label` is cached at link time for cheap display.
model NoteLink {
  id         String       @id @default(cuid())
  noteId     String
  note       Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  targetType NoteLinkType
  targetId   String
  label      String
  createdAt  DateTime     @default(now())

  @@unique([noteId, targetType, targetId])
  @@index([noteId])
}

enum CodeCategory {
  SOC
  SIEM
  THREAT_HUNTING
  INCIDENT_RESPONSE
  VULNERABILITY_MANAGEMENT
  GRC
  PENETRATION_TESTING
  LINUX
  NETWORKING
  CLOUD_SECURITY
  DETECTION_ENGINEERING
}

/// Folders for organizing code snippets (previously a free-text
/// string on CodeSnippet). Created on demand from the details panel.
model CodeFolder {
  id        String        @id @default(cuid())
  name      String        @unique
  snippets  CodeSnippet[]
  createdAt DateTime      @default(now())
}

model CodeSnippet {
  id          String                 @id @default(cuid())
  title       String
  description String?
  language    String                 @default("python")
  code        String                 @default("")
  category    CodeCategory?
  difficulty  NoteDifficulty?
  folderId    String?
  folder      CodeFolder?            @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags        Tag[]
  versions    CodeSnippetVersion[]
  relations   CodeSnippetRelation[]
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([folderId])
  @@index([category])
  @@index([language])
}

/// Immutable snapshots of a snippet, captured by auto-save whenever
/// title/code change — same pattern as NoteVersion.
model CodeSnippetVersion {
  id        String      @id @default(cuid())
  snippetId String
  snippet   CodeSnippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  title     String
  code      String
  language  String      @default("python")
  cause     String      @default("autosave")
  createdAt DateTime    @default(now())

  @@index([snippetId, createdAt])
}

/// Knowledge-graph edge from a snippet to notes, projects, courses,
/// and lessons. Reuses NoteLinkType; only NOTE/PROJECT/COURSE/LESSON
/// are accepted by the API.
model CodeSnippetRelation {
  id         String       @id @default(cuid())
  snippetId  String
  snippet    CodeSnippet  @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  targetType NoteLinkType
  targetId   String
  label      String
  createdAt  DateTime     @default(now())

  @@unique([snippetId, targetType, targetId])
  @@index([snippetId])
}

model Diagram {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("flowchart")
  mermaidCode String   @default("")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Operations
// ─────────────────────────────────────────────

enum ProjectCategory {
  SOC_ANALYST
  SIEM
  THREAT_DETECTION
  INCIDENT_RESPONSE
  VULNERABILITY_MANAGEMENT
  GRC
  PENETRATION_TESTING
  LINUX_NETWORKING
  CLOUD_SECURITY
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  category    ProjectCategory @default(SOC_ANALYST)
  status      ProjectStatus   @default(PLANNED)
  progress    Int             @default(0)
  dueDate     DateTime?
  tags        Tag[]
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum ReportType {
  INCIDENT_RESPONSE
  VULNERABILITY
  GRC
  THREAT_INTEL
  RISK_ASSESSMENT
  SECURITY_ASSESSMENT
}

enum ReportSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFORMATIONAL
}

enum ReportStatus {
  DRAFT
  IN_REVIEW
  FINAL
}

model Report {
  id        String         @id @default(cuid())
  title     String
  type      ReportType     @default(INCIDENT_RESPONSE)
  severity  ReportSeverity @default(MEDIUM)
  status    ReportStatus   @default(DRAFT)
  reference String?
  content   String         @default("")
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([type])
}

// SIEM detection rules
model SiemRule {
  id          String         @id @default(cuid())
  title       String
  platform    String         @default("Splunk")
  description String?
  query       String         @default("")
  mitre       String?
  severity    ReportSeverity @default(MEDIUM)
  enabled     Boolean        @default(true)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum HuntStatus {
  PROPOSED
  ACTIVE
  COMPLETED
  ARCHIVED
}

model ThreatHunt {
  id         String     @id @default(cuid())
  title      String
  hypothesis String     @default("")
  dataSource String?
  mitre      String?
  status     HuntStatus @default(PROPOSED)
  findings   String?
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum IocType {
  IP
  DOMAIN
  URL
  FILE_HASH
  EMAIL
  REGISTRY
}

model Ioc {
  id         String   @id @default(cuid())
  type       IocType  @default(IP)
  value      String
  threatType String?
  source     String?
  confidence String   @default("Medium")
  notes      String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([type])
}

// ─────────────────────────────────────────────
// Learning
// ─────────────────────────────────────────────

enum ModuleStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model LearningProgress {
  id         String       @id @default(cuid())
  track      String
  module     String
  status     ModuleStatus @default(NOT_STARTED)
  progress   Int          @default(0)
  hoursSpent Float        @default(0)
  order      Int          @default(0)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([track])
}

enum ResourceType {
  COURSE
  CERTIFICATION
  BOOK
  VIDEO
  LAB
  TOOL
  ARTICLE
}

enum ResourceStatus {
  TO_START
  IN_PROGRESS
  COMPLETED
}

model Resource {
  id        String         @id @default(cuid())
  title     String
  url       String?
  type      ResourceType   @default(COURSE)
  provider  String?
  status    ResourceStatus @default(TO_START)
  notes     String?
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// Legacy lightweight daily study log (kept for dashboard bar chart)
model StudyLog {
  id      String   @id @default(cuid())
  date    DateTime
  minutes Int
  topic   String?
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date])
}

// Rich study sessions (timer / logged sessions)
model StudySession {
  id        String    @id @default(cuid())
  date      DateTime  @default(now())
  minutes   Int       @default(0)
  topic     String
  focus     String?
  notes     String?
  courseId  String?
  course    Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lessonId  String?
  lesson    Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([date])
}

enum GoalType {
  WEEKLY_HOURS
  DAILY_HOURS
  MODULES
  SESSIONS
  CUSTOM
}

model StudyGoal {
  id          String   @id @default(cuid())
  title       String
  type        GoalType @default(WEEKLY_HOURS)
  target      Float    @default(0)
  current     Float    @default(0)
  unit        String   @default("hours")
  active      Boolean  @default(true)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Course Library (e.g. 10Alytics)
// ─────────────────────────────────────────────

model Course {
  id          String         @id @default(cuid())
  title       String
  provider    String         @default("10Alytics")
  description String?
  progress    Int            @default(0)
  status      ModuleStatus   @default(IN_PROGRESS)
  modules     CourseModule[]
  sessions    StudySession[]
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model CourseModule {
  id       String   @id @default(cuid())
  title    String
  order    Int      @default(0)
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@index([courseId])
}

model Lesson {
  id            String         @id @default(cuid())
  title         String
  order         Int            @default(0)
  status        ModuleStatus   @default(NOT_STARTED)
  moduleId      String
  module        CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  notes         Note[]
  studySessions StudySession[]
  labs          Lab[]
  skills        LessonSkill[]

  @@index([moduleId])
}

// ─────────────────────────────────────────────
// Flashcards
// ─────────────────────────────────────────────

model Flashcard {
  id           String    @id @default(cuid())
  deck         String    @default("General")
  front        String
  back         String
  timesSeen    Int       @default(0)
  confidence   Int       @default(0) // 0-5
  lastReviewed DateTime?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([deck])
}

// ─────────────────────────────────────────────
// Career Center
// ─────────────────────────────────────────────

model Resume {
  id        String   @id @default(cuid())
  title     String
  targetRole String  @default("SOC Analyst")
  content   Json
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications JobApplication[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoverLetter {
  id        String   @id @default(cuid())
  title     String
  company   String?
  role      String?
  content   String   @default("")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications JobApplication[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LinkedInProfile {
  id            String   @id @default(cuid())
  headline      String   @default("")
  about         String   @default("")
  skills        String[] @default([])
  certifications String[] @default([])
  featured      String   @default("")
  checklist     Json?
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt     DateTime @updatedAt
}

enum JobStatus {
  DISCOVERED
  SAVED
  PREPARING
  READY_TO_APPLY
  APPLIED
  RECRUITER_CONTACT
  ASSESSMENT
  INTERVIEW
  FINAL_INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
  ARCHIVED
}

enum ApplicationSource {
  DISCOVERY // created by saving a JobPosting
  MANUAL // entered by hand
}

enum InterviewType {
  RECRUITER_SCREEN
  HR_INTERVIEW
  HIRING_MANAGER
  TECHNICAL_INTERVIEW
  SOC_SCENARIO
  BEHAVIOURAL
  PANEL
  EXECUTIVE
  FINAL_INTERVIEW
  OTHER
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum AssessmentType {
  TECHNICAL_TEST
  CODING_TEST
  CYBERSECURITY_LAB
  SOC_INVESTIGATION
  TAKE_HOME
  PERSONALITY
  COGNITIVE
  BACKGROUND_CHECK
  OTHER
}

enum AssessmentStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  PASSED
  FAILED
  EXPIRED
  CANCELLED
}

enum OfferDecision {
  PENDING
  ACCEPTED
  DECLINED
  NEGOTIATING
}

enum ApplicationNoteCategory {
  GENERAL
  RECRUITER
  INTERVIEW
  TECHNICAL
  FOLLOW_UP
  SALARY
  COMPANY_RESEARCH
}

model JobApplication {
  id            String    @id @default(cuid())
  company       String
  jobTitle      String
  location      String?
  salary        String?
  url           String?
  status        JobStatus @default(SAVED)
  source        ApplicationSource @default(DISCOVERY)
  appliedDate   DateTime?
  interviewDate DateTime?
  notes         String?
  // Denormalized job metadata (esp. for MANUAL entries; discovered
  // applications also read these from the linked jobPosting).
  workplaceType WorkplaceType?
  employmentType JobEmploymentType?
  applicationUrl String?
  matchScore    Int?
  // Lifecycle timestamps
  discoveredAt  DateTime?
  savedAt       DateTime? @default(now())
  lastActivityAt DateTime? @default(now())
  // Job-discovery integration (v0.4)
  jobPostingId  String?
  jobPosting    JobPosting?  @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  resumeId      String?
  resume        Resume?      @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  resumeVersion String?
  coverLetterId String?
  coverLetter   CoverLetter? @relation(fields: [coverLetterId], references: [id], onDelete: SetNull)
  coverLetterVersion String?
  contactPerson String?
  recruiter     String?
  // Structured contacts
  recruiterName    String?
  recruiterTitle   String?
  recruiterCompany String?
  recruiterEmail   String?
  recruiterPhone   String?
  hiringManagerName  String?
  hiringManagerEmail String?
  contactNotes     String?
  // Follow-up
  followUpDate      DateTime?
  followUpReason    String?
  followUpCompleted Boolean  @default(false)
  followUpNotes     String?
  // Reopen bookkeeping — status a closed app returns to on reopen.
  reopenedAt    DateTime?
  events        JobApplicationEvent[]
  interviews    ApplicationInterview[]
  assessments   ApplicationAssessment[]
  offer         ApplicationOffer?
  appNotes      ApplicationNote[]
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, jobPostingId])
  @@index([status])
  @@index([jobPostingId])
  @@index([userId, status])
  @@index([userId, followUpDate])
}

/// Activity timeline for an application (status changes, notes,
/// interviews, follow-ups). Append-only, auditable.
model JobApplicationEvent {
  id            String         @id @default(cuid())
  applicationId String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String?
  kind          String // see APPLICATION_EVENT_KINDS in lib/applications/timeline.ts
  summary       String?
  note          String?
  metadata      Json?
  occurredAt    DateTime       @default(now())
  createdAt     DateTime       @default(now())

  @@index([applicationId, occurredAt])
}

model ApplicationInterview {
  id            String          @id @default(cuid())
  applicationId String
  application   JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          InterviewType   @default(OTHER)
  stage         String?
  status        InterviewStatus @default(SCHEDULED)
  scheduledAt   DateTime?
  startTime     DateTime?
  endTime       DateTime?
  timezone      String?
  interviewers  String[]        @default([])
  locationOrLink String?
  prepNotes     String?
  questionsAsked String?
  reflections   String?
  technicalTopics String[]      @default([])
  outcome       String?
  followUpRequired Boolean      @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([applicationId])
  @@index([userId])
}

model ApplicationAssessment {
  id            String           @id @default(cuid())
  applicationId String
  application   JobApplication   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  type          AssessmentType   @default(OTHER)
  provider      String?
  receivedAt    DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  status        AssessmentStatus @default(NOT_STARTED)
  score         String?
  result        String?
  link          String?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([applicationId])
  @@index([userId])
}

model ApplicationOffer {
  id             String        @id @default(cuid())
  applicationId  String        @unique
  application    JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  receivedDate   DateTime?
  positionTitle  String?
  baseSalary     Float?
  salaryCurrency String?       @default("CAD")
  salaryPeriod   String?       @default("YEAR")
  bonus          String?
  equity         String?
  vacationDays   Int?
  benefitsNotes  String?
  remotePolicy   String?
  officeLocation String?
  startDate      DateTime?
  expiryDate     DateTime?
  negotiationNotes String?
  decision       OfferDecision @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
}

model ApplicationNote {
  id            String                  @id @default(cuid())
  applicationId String
  application   JobApplication          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  body          String
  category      ApplicationNoteCategory @default(GENERAL)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([applicationId])
  @@index([userId])
}

model InterviewPrep {
  id        String   @id @default(cuid())
  category  String   @default("General")
  question  String
  answer    String   @default("")
  confidence Int     @default(0) // 0-5
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("Project")
  url         String?
  repoUrl     String?
  tech        String[] @default([])
  featured    Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Job Discovery & Career Tracking (v0.4)
//
// Entity mapping vs. the spec:
//   LearningProgram → existing Course (provider field)
//   CoursePhase     → existing CourseModule (order field)
//   PortfolioArtifact → PortfolioRepo + CybersecurityProject.artifactUrl
// ─────────────────────────────────────────────

enum JobSourceType {
  HIRING_CAFE // unofficial endpoint — experimental, disabled by default
  GREENHOUSE
  LEVER
  ASHBY
  SMARTRECRUITERS
  WORKDAY // unofficial per-tenant endpoint — experimental
  JOB_BANK_CA // RSS-based — no official API
  EMPLOYER_DIRECT
  MANUAL
}

enum WorkplaceType {
  REMOTE
  HYBRID
  ON_SITE
  UNKNOWN
}

enum JobEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
  COMMISSION
  UNKNOWN
}

enum SeniorityLevel {
  ENTRY
  ASSOCIATE
  INTERMEDIATE
  SENIOR
  LEAD
  UNKNOWN
}

enum SalaryPeriod {
  HOUR
  DAY
  WEEK
  MONTH
  YEAR
}

enum ImportRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

/// How a skill claim is backed. Training labs are never presented
/// as professional experience (spec requirement).
enum SkillProvenance {
  PROFESSIONAL
  PERSONAL_PROJECT
  TRAINING_LAB
  CERTIFICATION
  DEMONSTRATED
  FAMILIARITY
}

enum CertificationStatus {
  PLANNED
  IN_PROGRESS
  EARNED
  EXPIRED
}

enum NotificationType {
  HIGH_MATCH
  VANCOUVER_JOB
  REMOTE_CANADA_JOB
  EXPIRING_SOON
  DEADLINE_APPROACHING
  FOLLOW_UP_DUE
  TRENDING_SKILL
  PROJECT_MATCH
  SYSTEM
}

/// One normalized job posting. Multiple discovered sources attach
/// via JobPostingSource; the employer's direct link wins as
/// applicationUrl when available.
model JobPosting {
  id                String  @id @default(cuid())
  // Dedup identity
  normalizedTitle   String
  normalizedCompany String
  duplicateGroupId  String?
  // Display
  title             String
  company           String
  companyLogo       String?
  description       String  @default("")
  responsibilities  String?
  requiredSkillsText  String[] @default([])
  preferredSkillsText String[] @default([])
  // Location
  location       String?
  city           String?
  province       String?
  country        String?
  workplaceType  WorkplaceType     @default(UNKNOWN)
  employmentType JobEmploymentType @default(UNKNOWN)
  seniority      SeniorityLevel    @default(UNKNOWN)
  /// 1 (Vancouver) … 7 (US remote accepting Canadians); 99 = ineligible
  locationPriority Int @default(99)
  // Compensation
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?
  salaryPeriod   SalaryPeriod?
  // Eligibility
  acceptsCanadianApplicants Boolean  @default(true)
  requiresUSResidency       Boolean  @default(false)
  requiresCitizenship       Boolean  @default(false)
  requiresSecurityClearance Boolean  @default(false)
  visaSponsorship           Boolean?
  // Lifecycle (spec: never rely on importedAt alone for the 7-day rule)
  sourcePostedAt DateTime?
  firstSeenAt    DateTime  @default(now())
  lastVerifiedAt DateTime  @default(now())
  expiresAt      DateTime?
  importedAt     DateTime  @default(now())
  isActive       Boolean   @default(true)
  archivedAt     DateTime?
  // Matching (recomputed by JobMatchingService; single-user app)
  matchScore        Int?
  matchBreakdown    Json?
  matchedSkills     String[] @default([])
  missingSkills     String[] @default([])
  /// Count of missing REQUIRED skills (fewest-gaps sorting)
  missingSkillCount Int?
  // Apply links (employer-direct preferred)
  applicationUrl   String?
  primarySourceUrl String?

  sources           JobPostingSource[]
  skillRequirements JobSkillRequirement[]
  applications      JobApplication[]
  notifications     Notification[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive, sourcePostedAt])
  @@index([normalizedCompany, normalizedTitle])
  @@index([matchScore])
  @@index([missingSkillCount])
  @@index([locationPriority])
}

/// A place where a posting was discovered. One posting may appear on
/// HiringCafe, an ATS board, and the employer site simultaneously.
model JobPostingSource {
  id             String        @id @default(cuid())
  jobPostingId   String
  jobPosting     JobPosting    @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  sourceType     JobSourceType
  sourceJobId    String?
  sourceUrl      String
  applicationUrl String?
  raw            Json?
  importedAt     DateTime      @default(now())
  lastSeenAt     DateTime      @default(now())

  @@unique([sourceType, sourceUrl])
  @@index([jobPostingId])
}

/// A configured source to poll, e.g. one Greenhouse board slug or a
/// Job Bank RSS query. Providers read these; secrets stay in env vars.
model JobSourceConfig {
  id         String           @id @default(cuid())
  sourceType JobSourceType
  /// Provider-specific identifier: board slug, tenant, feed URL, …
  identifier String
  label      String
  enabled    Boolean          @default(true)
  /// False for reverse-engineered endpoints (HiringCafe, Workday)
  official   Boolean          @default(true)
  lastRunAt  DateTime?
  lastStatus ImportRunStatus?
  createdAt  DateTime         @default(now())

  importRuns ImportRun[]

  @@unique([sourceType, identifier])
}

/// Audit log for every ingestion run (source health monitoring).
model ImportRun {
  id           String           @id @default(cuid())
  sourceType   JobSourceType
  configId     String?
  config       JobSourceConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)
  status       ImportRunStatus  @default(RUNNING)
  startedAt    DateTime         @default(now())
  finishedAt   DateTime?
  jobsFound    Int              @default(0)
  jobsCreated  Int              @default(0)
  jobsUpdated  Int              @default(0)
  jobsArchived Int              @default(0)
  error        String?
  details      Json?

  @@index([sourceType, startedAt])
}

// ── Skills & career profile ──────────────────

model Skill {
  id       String   @id @default(cuid())
  name     String   @unique
  aliases  String[] @default([])
  category String   @default("General") // SIEM, Cloud, GRC, Tooling, …
  createdAt DateTime @default(now())

  userSkills   UserSkill[]
  requirements JobSkillRequirement[]
  lessons      LessonSkill[]
  labs         LabSkill[]
  projects     ProjectSkill[]
}

model UserSkill {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  provenance SkillProvenance @default(FAMILIARITY)
  /// Where this claim comes from (lab id, repo, cert name, …)
  evidence   String?
  acquiredAt DateTime        @default(now())

  @@unique([userId, skillId])
}

/// A skill a posting asks for, extracted during normalization.
model JobSkillRequirement {
  id           String     @id @default(cuid())
  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  skillId      String
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  required     Boolean    @default(true) // false = preferred
  rawText      String?

  @@unique([jobPostingId, skillId])
}

// ── Portfolio & credentials ──────────────────

/// A public GitHub repository. Only repos with includeInMatching
/// participate in match scoring (spec: user decides, repos are not
/// automatically presented as cybersecurity experience).
model PortfolioRepo {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName          String // e.g. PrinceN09/log-parser
  name              String
  description       String?
  url               String
  homepage          String?
  languages         Json?
  topics            String[]  @default([])
  readmeSummary     String?
  /// 0–100 heuristic: README present, sections, license, …
  docCompleteness   Int?
  detectedSkills    String[]  @default([])
  includeInMatching Boolean   @default(false)
  lastPushedAt      DateTime?
  syncedAt          DateTime  @default(now())
  createdAt         DateTime  @default(now())

  @@unique([userId, fullName])
}

model Certification {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  issuer        String?
  status        CertificationStatus @default(PLANNED)
  earnedAt      DateTime?
  expiresAt     DateTime?
  credentialUrl String?
  createdAt     DateTime            @default(now())
}

// ── Training integration ─────────────────────

model Lab {
  id          String       @id @default(cuid())
  title       String
  description String?
  lessonId    String?
  lesson      Lesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  status      ModuleStatus @default(NOT_STARTED)
  completedAt DateTime?
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills      LabSkill[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([lessonId])
}

model CybersecurityProject {
  id          String         @id @default(cuid())
  title       String
  description String?
  repoUrl     String?
  artifactUrl String?
  status      ModuleStatus   @default(NOT_STARTED)
  completedAt DateTime?
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills      ProjectSkill[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model LessonSkill {
  id       String @id @default(cuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  skillId  String
  skill    Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([lessonId, skillId])
}

model LabSkill {
  id      String @id @default(cuid())
  labId   String
  lab     Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([labId, skillId])
}

model ProjectSkill {
  id        String               @id @default(cuid())
  projectId String
  project   CybersecurityProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill                @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillId])
}

// ── Notifications ────────────────────────────

model Notification {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         NotificationType
  title        String
  body         String?
  jobPostingId String?
  jobPosting   JobPosting?      @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  readAt       DateTime?
  createdAt    DateTime         @default(now())

  @@index([userId, createdAt])
}

/// Per-user job-search preferences. Eligibility, priority ranking,
/// and match scoring consume these — never hard-coded values.
/// Defaults mirror DEFAULT_JOB_PREFERENCES in lib/jobs/preferences.ts.
model JobSearchPreference {
  id                       String              @id @default(cuid())
  userId                   String              @unique
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeCity                 String              @default("Vancouver")
  homeProvince             String              @default("BC")
  homeCountry              String              @default("Canada")
  willingToRelocate        Boolean             @default(true)
  relocationCountries      String[]            @default(["Canada"])
  preferredCountries       String[]            @default(["Canada"])
  remoteCanada             Boolean             @default(true)
  remoteUSIfCanadaEligible Boolean             @default(true)
  hybridCanada             Boolean             @default(true)
  onsiteCanada             Boolean             @default(true)
  employmentTypes          JobEmploymentType[] @default([FULL_TIME])
  permanentPreferred       Boolean             @default(true)
  maxJobAgeDays            Int                 @default(7)
  minimumMatchScore        Int                 @default(0)
  /// Validated WorkplaceZoneKey[] (see lib/jobs/preferences.ts)
  preferredWorkplaceOrder  Json?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
}

model NotificationRule {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  enabled   Boolean          @default(true)
  /// e.g. minimum match score for HIGH_MATCH
  threshold Int?
  config    Json?
  createdAt DateTime         @default(now())

  @@unique([userId, type])
}
