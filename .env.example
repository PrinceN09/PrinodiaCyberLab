# ─────────────────────────────────────────────────────────────
# Prinodia CyberLab — example environment configuration
#
# This file contains PLACEHOLDERS ONLY. Copy it to `.env` and fill in
# real values locally. Generate all secrets on your own machine.
#
#   - `.env` must NEVER be committed (it is gitignored).
#   - Do not reuse development credentials in production.
#   - Rotate any secret that is ever exposed or shared.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/prinodia_cyberlab?schema=public"

# Secret used to sign session cookies. Generate a long random value, e.g.:
#   openssl rand -hex 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Local development admin account. The seed script reads these, validates
# them, hashes the password, and NEVER prints or stores plaintext.
# Use a strong, unique password for local development only.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="replace-with-a-strong-local-development-password"

# ── Job discovery ────────────────────────────────────────────
# Secret required by the scheduled-refresh endpoint. Generate locally, e.g.:
#   openssl rand -hex 32
JOBS_REFRESH_SECRET="replace-with-a-random-local-secret"

# Unofficial providers are OFF unless explicitly enabled (they use
# undocumented endpoints and may break or violate source ToS —
# review before enabling; see src/lib/jobs/registry.ts).
HIRING_CAFE_ENABLED="false"
WORKDAY_ENABLED="false"

# GitHub portfolio sync. Optional: a fine-grained token with public-repo
# read raises rate limits; public data works unauthenticated at 60 req/hr.
# Never commit a real token — leave blank unless set locally.
GITHUB_USERNAME="your-github-username"
GITHUB_TOKEN=""
