generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Core
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   @default("")
  role      String   @default("Security Analyst")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes            Note[]
  codeSnippets     CodeSnippet[]
  diagrams         Diagram[]
  projects         Project[]
  reports          Report[]
  learningProgress LearningProgress[]
  resources        Resource[]
  studyLogs        StudyLog[]
  studySessions    StudySession[]
  studyGoals       StudyGoal[]
  courses          Course[]
  flashcards       Flashcard[]
  resumes          Resume[]
  coverLetters     CoverLetter[]
  linkedInProfile  LinkedInProfile?
  jobApplications  JobApplication[]
  interviewPreps   InterviewPrep[]
  portfolioItems   PortfolioItem[]
  siemRules        SiemRule[]
  threatHunts      ThreatHunt[]
  iocs             Ioc[]
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[] @relation("FolderTree")
  notes     Note[]
  createdAt DateTime @default(now())
}

model Tag {
  id       String        @id @default(cuid())
  name     String        @unique
  color    String        @default("blue")
  notes    Note[]
  snippets CodeSnippet[]
  projects Project[]
}

/// Managed vocabulary for note categories (previously a free-text
/// string on Note). Created on demand from the note details form.
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("blue")
  notes     Note[]
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// Knowledge base
// ─────────────────────────────────────────────

enum NoteStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum NoteDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Note {
  id          String          @id @default(cuid())
  title       String
  summary     String?
  description String?
  content     String          @default("")
  status      NoteStatus      @default(DRAFT)
  difficulty  NoteDifficulty?
  pinned      Boolean         @default(false)
  favorite    Boolean         @default(false)
  categoryId  String?
  category    Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  folderId    String?
  folder      Folder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags        Tag[]
  lessonId    String?
  lesson      Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions    NoteVersion[]
  attachments Attachment[]
  links       NoteLink[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([folderId])
  @@index([lessonId])
  @@index([categoryId])
  @@index([status])
}

/// Immutable point-in-time snapshots of a note, captured by the
/// auto-save pipeline on every content change. Powers version
/// history (list, preview, restore). Never updated in place.
model NoteVersion {
  id        String   @id @default(cuid())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  title     String
  content   String
  cause     String   @default("autosave") // autosave | manual | restore
  createdAt DateTime @default(now())

  @@index([noteId, createdAt])
}

/// File attachment metadata. The binary lives on disk under
/// uploads/notes/<noteId>/ and is streamed via the attachments API.
model Attachment {
  id          String   @id @default(cuid())
  noteId      String
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  fileName    String
  mimeType    String
  size        Int
  storagePath String
  createdAt   DateTime @default(now())

  @@index([noteId])
}

enum NoteLinkType {
  COURSE
  LESSON
  PROJECT
  CODE_SNIPPET
  DIAGRAM
  STUDY_SESSION
  INTERVIEW_QUESTION
  PORTFOLIO_ITEM
  REPORT
  NOTE
}

/// Knowledge-graph edge from a note to any other entity in the
/// workspace (courses, lessons, snippets, other notes, …).
/// `label` is cached at link time for cheap display.
model NoteLink {
  id         String       @id @default(cuid())
  noteId     String
  note       Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  targetType NoteLinkType
  targetId   String
  label      String
  createdAt  DateTime     @default(now())

  @@unique([noteId, targetType, targetId])
  @@index([noteId])
}

model CodeSnippet {
  id          String   @id @default(cuid())
  title       String
  description String?
  language    String   @default("python")
  code        String   @default("")
  folder      String?
  tags        Tag[]
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Diagram {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("flowchart")
  mermaidCode String   @default("")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Operations
// ─────────────────────────────────────────────

enum ProjectCategory {
  SOC_ANALYST
  SIEM
  THREAT_DETECTION
  INCIDENT_RESPONSE
  VULNERABILITY_MANAGEMENT
  GRC
  PENETRATION_TESTING
  LINUX_NETWORKING
  CLOUD_SECURITY
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  category    ProjectCategory @default(SOC_ANALYST)
  status      ProjectStatus   @default(PLANNED)
  progress    Int             @default(0)
  dueDate     DateTime?
  tags        Tag[]
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum ReportType {
  INCIDENT_RESPONSE
  VULNERABILITY
  GRC
  THREAT_INTEL
  RISK_ASSESSMENT
  SECURITY_ASSESSMENT
}

enum ReportSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFORMATIONAL
}

enum ReportStatus {
  DRAFT
  IN_REVIEW
  FINAL
}

model Report {
  id        String         @id @default(cuid())
  title     String
  type      ReportType     @default(INCIDENT_RESPONSE)
  severity  ReportSeverity @default(MEDIUM)
  status    ReportStatus   @default(DRAFT)
  reference String?
  content   String         @default("")
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([type])
}

// SIEM detection rules
model SiemRule {
  id          String         @id @default(cuid())
  title       String
  platform    String         @default("Splunk")
  description String?
  query       String         @default("")
  mitre       String?
  severity    ReportSeverity @default(MEDIUM)
  enabled     Boolean        @default(true)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum HuntStatus {
  PROPOSED
  ACTIVE
  COMPLETED
  ARCHIVED
}

model ThreatHunt {
  id         String     @id @default(cuid())
  title      String
  hypothesis String     @default("")
  dataSource String?
  mitre      String?
  status     HuntStatus @default(PROPOSED)
  findings   String?
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum IocType {
  IP
  DOMAIN
  URL
  FILE_HASH
  EMAIL
  REGISTRY
}

model Ioc {
  id         String   @id @default(cuid())
  type       IocType  @default(IP)
  value      String
  threatType String?
  source     String?
  confidence String   @default("Medium")
  notes      String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([type])
}

// ─────────────────────────────────────────────
// Learning
// ─────────────────────────────────────────────

enum ModuleStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model LearningProgress {
  id         String       @id @default(cuid())
  track      String
  module     String
  status     ModuleStatus @default(NOT_STARTED)
  progress   Int          @default(0)
  hoursSpent Float        @default(0)
  order      Int          @default(0)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([track])
}

enum ResourceType {
  COURSE
  CERTIFICATION
  BOOK
  VIDEO
  LAB
  TOOL
  ARTICLE
}

enum ResourceStatus {
  TO_START
  IN_PROGRESS
  COMPLETED
}

model Resource {
  id        String         @id @default(cuid())
  title     String
  url       String?
  type      ResourceType   @default(COURSE)
  provider  String?
  status    ResourceStatus @default(TO_START)
  notes     String?
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// Legacy lightweight daily study log (kept for dashboard bar chart)
model StudyLog {
  id      String   @id @default(cuid())
  date    DateTime
  minutes Int
  topic   String?
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date])
}

// Rich study sessions (timer / logged sessions)
model StudySession {
  id        String    @id @default(cuid())
  date      DateTime  @default(now())
  minutes   Int       @default(0)
  topic     String
  focus     String?
  notes     String?
  courseId  String?
  course    Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lessonId  String?
  lesson    Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([date])
}

enum GoalType {
  WEEKLY_HOURS
  DAILY_HOURS
  MODULES
  SESSIONS
  CUSTOM
}

model StudyGoal {
  id          String   @id @default(cuid())
  title       String
  type        GoalType @default(WEEKLY_HOURS)
  target      Float    @default(0)
  current     Float    @default(0)
  unit        String   @default("hours")
  active      Boolean  @default(true)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Course Library (e.g. 10Alytics)
// ─────────────────────────────────────────────

model Course {
  id          String         @id @default(cuid())
  title       String
  provider    String         @default("10Alytics")
  description String?
  progress    Int            @default(0)
  status      ModuleStatus   @default(IN_PROGRESS)
  modules     CourseModule[]
  sessions    StudySession[]
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model CourseModule {
  id       String   @id @default(cuid())
  title    String
  order    Int      @default(0)
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@index([courseId])
}

model Lesson {
  id            String         @id @default(cuid())
  title         String
  order         Int            @default(0)
  status        ModuleStatus   @default(NOT_STARTED)
  moduleId      String
  module        CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  notes         Note[]
  studySessions StudySession[]

  @@index([moduleId])
}

// ─────────────────────────────────────────────
// Flashcards
// ─────────────────────────────────────────────

model Flashcard {
  id           String    @id @default(cuid())
  deck         String    @default("General")
  front        String
  back         String
  timesSeen    Int       @default(0)
  confidence   Int       @default(0) // 0-5
  lastReviewed DateTime?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([deck])
}

// ─────────────────────────────────────────────
// Career Center
// ─────────────────────────────────────────────

model Resume {
  id        String   @id @default(cuid())
  title     String
  targetRole String  @default("SOC Analyst")
  content   Json
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoverLetter {
  id        String   @id @default(cuid())
  title     String
  company   String?
  role      String?
  content   String   @default("")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LinkedInProfile {
  id            String   @id @default(cuid())
  headline      String   @default("")
  about         String   @default("")
  skills        String[] @default([])
  certifications String[] @default([])
  featured      String   @default("")
  checklist     Json?
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt     DateTime @updatedAt
}

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

model JobApplication {
  id            String    @id @default(cuid())
  company       String
  jobTitle      String
  location      String?
  salary        String?
  url           String?
  status        JobStatus @default(SAVED)
  appliedDate   DateTime?
  interviewDate DateTime?
  notes         String?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

model InterviewPrep {
  id        String   @id @default(cuid())
  category  String   @default("General")
  question  String
  answer    String   @default("")
  confidence Int     @default(0) // 0-5
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("Project")
  url         String?
  repoUrl     String?
  tech        String[] @default([])
  featured    Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
